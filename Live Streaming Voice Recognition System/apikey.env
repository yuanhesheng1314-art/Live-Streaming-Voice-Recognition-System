# ========== DashScope（实时语音识别） ==========
DASHSCOPE_API_KEY=sk-9dc2a254bab640a6bc20b875f9c9d05d
DASHSCOPE_ASR_MODEL=qwen3-asr-flash-realtime
DASHSCOPE_REALTIME_WS_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
ASR_SESSION_UPDATED_TIMEOUT_SEC=45

# ========== Ollama 本地终审（准确率优先，A100 40G 稳态） ==========
OLLAMA_CHAT_URL=http://127.0.0.1:11434/api/chat
OLLAMA_GENERATE_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen3:8b
OLLAMA_MODEL_FALLBACK=qwen2.5:3b
OLLAMA_MODEL_FAST=qwen2.5:3b

# 并发与网络（先稳态，避免过高并发拖慢单句）
OLLAMA_GLOBAL_MAX_CONCURRENT=6
OLLAMA_MAX_CONCURRENT=6
OLLAMA_HTTP_READ_TIMEOUT=120

# 推理预算（兼顾准确率和时延）
OLLAMA_NUM_PREDICT=256
OLLAMA_NUM_PREDICT_WITH_THINK=512
OLLAMA_TOP_P=0.88
OLLAMA_REPEAT_PENALTY=1.12
LLM_AUDIT_NUM_CTX=1536
LLM_FAST_NUM_CTX=768
LLM_CONTEXT_TURNS=5
LLM_SINGLE_TIMEOUT_SEC=45
LLM_FAST_TIMEOUT_SEC=28
LLM_SEM_WAIT_TIMEOUT_SEC=20
LLM_RECHECK_TIMEOUT_SEC=15

# 主链路（准确率优先）
LLM_AUDIT_SINGLE_CALL=1
LLM_USE_FAST_MODEL=0
LLM_PARSE_RETRY=1
LLM_ENABLE_SUSPECT_RECHECK=1
LLM_ENABLE_HIGHCONF_RULE_PREFILTER=0
LLM_ENABLE_BENIGN_PREFILTER=0
ENABLE_CROSS_SENTENCE_RULE=1
ENABLE_CONFLICT_RECHECK=1
ENABLE_DYNAMIC_RECHECK_GUARD=1
ENABLE_DUAL_STAGE_AUDIT=0

# 超时/漏判兜底（需对应 pcm_lsjs.py 版本）
LLM_TIMEOUT_RETRY_ONCE=1
LLM_TIMEOUT_RETRY_EXTRA_SEC=18
AUDIT_SEND_QUEUE_ACK=1
LLM_SKIP_LOWINFO_UTTERANCE=1
LLM_ENABLE_RANDOM_MODEL_FALLBACK=0

# 队列与会话
WS_MAX_SESSIONS=8
MAX_QUEUE_SIZE=150
AUDIT_WORKERS_PER_SESSION=2
AUDIT_PRIORITY_QUEUE_RATIO=0.3
AUDIT_HI_BURST=3
AUDIT_DRAIN_TIMEOUT=600
AUDIT_QUEUE_BUDGET_MS=6000
TAIL_FAST_QUEUE_WAIT_MS=12000
ENABLE_QUEUE_BUDGET_DEGRADE=0
ENABLE_TAIL_FAST_DEGRADE=0
WS_AUDIO_RECEIVE_TIMEOUT=120

# DashScope ASR 断链重连
ASR_UPSTREAM_RECONNECT_RETRIES=5
ASR_UPSTREAM_RECONNECT_BACKOFF_SEC=2.0
ASR_UPSTREAM_RECONNECT_COOLDOWN_SEC=5.0
ASR_UPSTREAM_FATAL_FAIL_THRESHOLD=15
ASR_UPSTREAM_FATAL_FAIL_WINDOW_SEC=30
ASR_UPSTREAM_PAUSE_SEC=15
ASR_KEEPALIVE_ENABLED=1
ASR_KEEPALIVE_INTERVAL_SEC=4.0
ASR_KEEPALIVE_PCM_MS=100

# 可选功能（测试期）
ALERT_ENABLED=0
ALERT_WEBHOOK_URL=
ALERT_MIN_RISK=high
AUTH_ENABLED=0
AUTH_API_KEY=your_auth_key_here
AUDIT_PERF_LOG=1